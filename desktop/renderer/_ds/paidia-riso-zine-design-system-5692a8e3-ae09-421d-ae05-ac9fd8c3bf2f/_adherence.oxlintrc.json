{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/content/**",
              "components/surfaces/**",
              "runtime/**",
              "ui_kits/homepage/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Archivo Black|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Archivo Black, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BuildList'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|size|key|ref|className|style|children)$/]",
        "message": "<BuildList> doesn't accept that prop. Declared props: items, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='BuildList'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|sm)$/]",
        "message": "<BuildList> size must be one of 'lg' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:yellow|pink|ghost)$/]",
        "message": "<Button> variant must be one of 'yellow' | 'pink' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|eyebrow|title|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: href, eyebrow, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:yel|pink|ghost)$/]",
        "message": "<Chip> variant must be one of 'yel' | 'pink' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:pink|yellow)$/]",
        "message": "<Eyebrow> tone must be one of 'pink' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mark'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|tilt|children|key|ref|className|style|children)$/]",
        "message": "<Mark> doesn't accept that prop. Declared props: tone, tilt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:yellow|pink)$/]",
        "message": "<Mark> tone must be one of 'yellow' | 'pink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Plate'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|children|key|ref|className|style|children)$/]",
        "message": "<Plate> doesn't accept that prop. Declared props: tone, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Plate'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:yel|pink|paper)$/]",
        "message": "<Plate> tone must be one of 'yel' | 'pink' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|tone|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:yellow|pink)$/]",
        "message": "<Stat> tone must be one of 'yellow' | 'pink'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
